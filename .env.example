# Optional overrides for `docker compose -f deploy/docker-compose.yml up`.
# Defaults are baked into the compose file (devenvcgi), so no .env is needed
# for first run against devenvcgi. Copy to .env and override when targeting
# a different environment (test, preprod, …) or using custom client registrations.
#
# Clinician client: confidential. EHEALTH_CLIENT_SECRET is required.
# Citizen client: public. No secret needed.
# Contact the FUT platform team to register clients and obtain the client secret.
#
# The clinician client must carry the ehealth-system|xa coexistence tag to
# create EpisodeOfCare resources.

EHEALTH_ISSUER_URI=https://saml.<env>.ehealth.sundhed.dk/auth/realms/ehealth
EHEALTH_CLIENT_ID=<your-clinician-client-id>
EHEALTH_CLIENT_SECRET=<your-clinician-client-secret>

EHEALTH_CITIZEN_ISSUER_URI=https://saml.<env>.ehealth.sundhed.dk/auth/realms/nemlogin
EHEALTH_CITIZEN_CLIENT_ID=<your-citizen-client-id>

FHIR_SERVER_PATIENT=https://patient.<env>.ehealth.sundhed.dk/fhir
FHIR_SERVER_CARE_PLAN=https://careplan.<env>.ehealth.sundhed.dk/fhir
FHIR_SERVER_PLAN=https://plan.<env>.ehealth.sundhed.dk/fhir
FHIR_SERVER_ORGANIZATION=https://organization.<env>.ehealth.sundhed.dk/fhir
FHIR_SERVER_TERMINOLOGY=https://terminology.<env>.ehealth.sundhed.dk/fhir
