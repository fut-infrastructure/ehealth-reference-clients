# Optional overrides for `docker compose -f deploy/docker-compose.yml up`.
# Defaults are baked into the compose file (Trifork-internal env), so no
# .env is required for first run. Copy to `.env` and pass via
# `--env-file .env` only when you need to override.
# devenvcgi values will be swapped in as part of the public-release scrub.
#
# FUTSEmployee and FUTSCitizen are public clients in the Trifork env with
# wildcard redirect URIs, no client secret needed.

# FUTSEmployee carries no coexistence tag, so $create-episode-of-care 422s with
# "Missing coexistence-tags in JWToken". trifork_kol_medarbejder is the mock Telma
# clinician client
EHEALTH_ISSUER_URI=https://saml.fut.trifork.com/auth/realms/ehealth
EHEALTH_CLIENT_ID=trifork_kol_medarbejder
EHEALTH_CLIENT_SECRET=

EHEALTH_CITIZEN_ISSUER_URI=https://saml.fut.trifork.com/auth/realms/nemlogin
EHEALTH_CITIZEN_CLIENT_ID=FUTSCitizen

FHIR_SERVER_PATIENT=https://patient.fut.trifork.com/fhir
FHIR_SERVER_CARE_PLAN=https://careplan.fut.trifork.com/fhir
FHIR_SERVER_PLAN=https://plan.fut.trifork.com/fhir
FHIR_SERVER_ORGANIZATION=https://organization.fut.trifork.com/fhir
FHIR_SERVER_TERMINOLOGY=https://terminology.fut.trifork.com/fhir
FHIR_SERVER_MEASUREMENT=https://measurement.fut.trifork.com/fhir
FHIR_SERVER_TASK=https://task.fut.trifork.com/fhir
